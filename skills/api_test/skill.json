{
  "name": "api_test",
  "display_name": "API Endpoint Tester",
  "description": "Discovers API endpoints, tests HTTP methods, and checks for authentication bypass vulnerabilities.",
  "version": "1.0.0",
  "entry_point": "api_test.py",
  "parameters": {
    "target_url": {
      "type": "string",
      "description": "Base URL of the target application",
      "required": true
    },
    "scan_type": {
      "type": "string",
      "description": "Type of test: 'full', 'discovery', 'methods', 'auth_bypass'",
      "default": "full"
    },
    "wordlist": {
      "type": "string",
      "description": "Wordlist size for endpoint brute-force: 'small', 'medium', 'large'",
      "default": "medium"
    }
  },
  "tags": ["security", "api", "endpoint", "authentication"]
}
