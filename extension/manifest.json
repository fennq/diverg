{
  "manifest_version": 3,
  "name": "Diverg Security Scan",
  "version": "1.5.2",
  "description": "Run Diverg scans and simulate PoC for findings. Auto-scan sites, Solana bundle intel, side panel.",
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png"
  },
  "permissions": ["storage", "activeTab", "tabs", "sidePanel", "scripting"],
  "host_permissions": ["http://127.0.0.1:5000/*", "http://localhost:5000/*", "https://*/*", "http://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Diverg Scan",
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_page": "options.html"
}
