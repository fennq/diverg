{
  "manifest_version": 3,
  "name": "Diverg Security Scan",
  "version": "1.3.0",
  "description": "Run Diverg scans and simulate PoC for findings. Auto-scan sites and see risks in the side panel.",
  "permissions": ["storage", "activeTab", "tabs", "sidePanel", "scripting"],
  "host_permissions": ["http://127.0.0.1:5000/*", "http://localhost:5000/*", "https://*/*", "http://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Diverg Scan"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_page": "options.html"
}
