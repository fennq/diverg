# Optional: only for --use-openclaw (OpenClaw SDK). Leave unset to run Diverg standalone.
OPENCLAW_AUTH_TOKEN=change-me-to-a-random-secret

# OpenAI — used as the LLM reasoning backend
OPENAI_API_KEY=sk-...

# Security hardening (required in production)
# Set a stable JWT secret (32+ random chars). If unset, api_server rotates secret at boot.
DIVERG_JWT_SECRET=
# Audit retention window in days
DIVERG_AUDIT_LOG_RETENTION_DAYS=90
# Enable analyst proof replay endpoint
DIVERG_ENABLE_STRICT_PROOF_API=1

# Telegram — for delivering scan reports
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=your-chat-id-here

# Helius (Solana) — Wallet API + RPC; used by investigation pipeline and Python solana_bundle
# https://www.helius.dev/  (Chrome extension Solana tab uses its own key in Options, not this file)
HELIUS_API_KEY=

# Optional: Python solana_bundle caps (deep scan defaults: more DAS pages + more wallets + 2-hop funders)
# SOLANA_BUNDLE_MAX_HOLDERS=100
# SOLANA_BUNDLE_MAX_FUNDED_BY=120
# SOLANA_BUNDLE_DAS_MAX_PAGES=45
# SOLANA_BUNDLE_FUNDER_HOP2_MAX=56
# SOLANA_BUNDLE_LP_SKIP_MIN_PCT=12
# SOLANA_BUNDLE_FUNDER_TRANSFERS_LIMIT=100
# Optional: solana_bundle_signals (coordination heuristics; investigation/solana_bundle_signals.py)
# SOLANA_BUNDLE_FUNDING_BUCKET_SEC=5
# SOLANA_BUNDLE_LAMPORTS_REL_TOL=0.002
# SOLANA_BUNDLE_MAX_TRANSFER_FETCH=72
# SOLANA_BUNDLE_MAX_ENHANCED_FETCH=32
# SOLANA_BUNDLE_MAX_FUNDER_IDENTITY=56
# SOLANA_BUNDLE_ENHANCED_TX_LIMIT=55
# SOLANA_BUNDLE_SIGNAL_TRANSFERS_LIMIT=100

# Blockchain investigation — 100% real data only when set; leave empty to skip on-chain (reports state "skipped")
# Solana: https://solscan.io/ (Pro API). Required for token/transfer, account/transfer, flow graph.
SOLSCAN_PRO_API_KEY=
# Arkham Intel API — REQUIRED on the server for dashboard/extension blockchain lookups, Solana bundle intel,
# and whenever Solscan or Etherscan keys are used in blockchain_investigation. https://intel.arkm.com/api
ARKHAM_API_KEY=
# Optional: 1 = exit on boot if ARKHAM_API_KEY missing (stricter prod; default 0 so deploy healthchecks still pass)
# DIVERG_REQUIRE_ARKHAM=0
# Ethereum: https://etherscan.io/apis. Required for on-chain checks on ETH.
ETHERSCAN_API_KEY=
# Optional: comma-separated known CEX/mixer addresses to tag in flow graph (e.g. exchange deposit wallets)
# DIVERG_KNOWN_CEX_MIXER=addr1,addr2

# Bubblemaps (bubblemaps.io) — token holder maps, clusters, decentralization score. Get key: api@bubblemaps.io
BUBBLEMAPS_API_KEY=

# Bags.fm (Solana token launch / fee APIs) — https://dev.bags.fm/
# Section 1: creators, lifetime fees, claim events | Section 2: pool by mint | Section 3: per-claimer claim-stats + optional pool list | Section 4: Dexscreener + optional launch feed + optional vault→pool-config
BAGS_API_KEY=
# BAGS_BASE_URL=https://public-api-v2.bags.fm/api/v1
# Section 3 optional: fetch full GET /solana/bags/pools (large). Set true for ecosystem/migration scans only.
# BAGS_FETCH_POOLS_LIST=false
# BAGS_POOLS_ONLY_MIGRATED=false
# Section 3: GET /fee-share/admin/list for creator wallet(s) — set false to skip extra API calls
# BAGS_SECTION3_ADMIN_CHECK=true
# BAGS_SECTION3_ADMIN_MAX_WALLETS=1
# Section 4: GET /solana/dexscreener/order-availability (per token) — set false to skip
# BAGS_DEXSCREENER_AVAILABILITY_CHECK=true
# Section 4 optional: GET /token-launch/feed (large) and match requested mint; set BAGS_FETCH_LAUNCH_FEED_RAW=true to store full JSON in synq_data
# BAGS_FETCH_LAUNCH_FEED=false
# BAGS_FETCH_LAUNCH_FEED_RAW=false
# Section 4 optional: comma-separated fee-claimer vault pubkeys → POST /token-launch/state/pool-config
# BAGS_FEE_CLAIMER_VAULTS=

# X (Twitter) search — link wallets to X accounts. One of:
# X API v2: get Bearer Token from https://developer.x.com (Apps → your app → Keys and tokens).
X_API_BEARER_TOKEN=
# Or Nitter fallback (scrape): set to a Nitter instance base URL (e.g. https://nitter.poast.org). Many public instances are rate-limited.
# NITTER_BASE_URL=
