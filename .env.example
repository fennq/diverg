# Optional: only for --use-openclaw (OpenClaw SDK). Leave unset to run Diverg standalone.
OPENCLAW_AUTH_TOKEN=change-me-to-a-random-secret

# OpenAI — used as the LLM reasoning backend
OPENAI_API_KEY=sk-...

# Telegram — for delivering scan reports
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=your-chat-id-here

# Blockchain investigation — 100% real data only when set; leave empty to skip on-chain (reports state "skipped")
# Solana: https://solscan.io/ (Pro API). Required for token/transfer, account/transfer, flow graph.
SOLSCAN_PRO_API_KEY=
# Optional: wallet/entity labels (CEX, mixer, OTC). Improves flow diagram and crime report.
ARKHAM_API_KEY=
# Ethereum: https://etherscan.io/apis. Required for on-chain checks on ETH.
ETHERSCAN_API_KEY=
# Optional: comma-separated known CEX/mixer addresses to tag in flow graph (e.g. exchange deposit wallets)
# DIVERG_KNOWN_CEX_MIXER=addr1,addr2

# Bubblemaps (bubblemaps.io) — token holder maps, clusters, decentralization score. Get key: api@bubblemaps.io
BUBBLEMAPS_API_KEY=

# X (Twitter) search — link wallets to X accounts. One of:
# X API v2: get Bearer Token from https://developer.x.com (Apps → your app → Keys and tokens).
X_API_BEARER_TOKEN=
# Or Nitter fallback (scrape): set to a Nitter instance base URL (e.g. https://nitter.poast.org). Many public instances are rate-limited.
# NITTER_BASE_URL=
